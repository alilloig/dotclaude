        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "local": {
      "source": {
        "source": "directory",
        "path": "/Users/alilloig/workspace/claudefiles/plugins/local"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
