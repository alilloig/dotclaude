{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_COORDINATOR_MODE": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(done)",
      "Bash(while read f)",
      "Bash(do)",
      "Bash(if ! head -20 \"$f\")",
      "Bash(then)",
      "Bash(fi)",
      "Bash(tr:*)",
      "Bash(find:*)",
      "Bash(xargs -0 -I{} sh -c 'if ! head -20 \"\"{}\"\" | grep -q \"\"draft: true\"\"; then echo \"\"{}\"\"; fi')",
      "Bash(python3:*)",
      "Bash(do if head -20 \"$f\")",
      "Bash(then echo \"$f\")",
      "Bash(then rm \"$f\")",
      "Bash(while read d)",
      "Bash(do rm -rf \"$d\")",
      "Bash(git init:*)",
      "Bash(git remote add:*)",
      "Bash(git -C /Users/alilloig/workspace/sui-pilot status -u)",
      "Bash(git -C /Users/alilloig/workspace/sui-pilot diff)",
      "Bash(git -C /Users/alilloig/workspace/sui-pilot add AGENTS.md README.md sui-pilot.png .sui-docs/)",
      "Bash(git -C /Users/alilloig/workspace/sui-pilot commit -m \"$\\(cat <<''EOF''\nInitial commit: Sui documentation copilot for AI agents\n\nCurated local knowledge base of 180 Sui/Move MDX docs with an\nAGENTS.md index for AI agent discovery. Covers concepts, guides,\nreferences, and standards.\n\nCo-Authored-By: Claude Opus 4.5 <noreply@anthropic.com>\nEOF\n\\)\")",
      "Bash(git -C /Users/alilloig/workspace/sui-pilot push -u origin main)",
      "Bash(git -C /Users/alilloig/workspace/sui-pilot remote set-url:*)",
      "Bash(git -C /Users/alilloig/workspace/sui-pilot status)",
      "Bash(gh pr:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alilloig/.claude/hooks/sui-network-gate.sh",
            "if": "Bash(sui client:*)",
            "timeout": 10,
            "statusMessage": "Checking Sui network..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/alilloig/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "linear@claude-plugins-official": false,
    "playground@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "slack@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "telegram@claude-plugins-official": false,
    "remember@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "mcp-server-dev@claude-plugins-official": true,
    "notion@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "impeccable@impeccable": false,
    "code-forge@local": true,
    "code-forge-rig@local": true,
    "codex-bridge@local": true,
    "forge-bench@local": false,
    "sui-wallet@local": false,
    "sui-pilot@local": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "local": {
      "source": {
        "source": "directory",
        "path": "/Users/alilloig/workspace/claudefiles/plugins/local"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true,
  "autoMode": {
    "allow": [
      "pnpm commands are safe — install, dev, build, test, lint, etc.",
      "sui move build and sui move test are local-only, no gas cost",
      "read-only sui client commands: object, gas, active-env, envs, active-address, balance, addresses",
      "read-only git commands: status, log, diff, branch, show, stash list",
      "npx and bunx for running local tools"
    ],
    "soft_deny": [
      "git push — affects remote, always confirm",
      "git reset --hard or git checkout -- — destructive, can lose work",
      "rm -rf — destructive file deletion",
      "sui client switch --env mainnet — switching to mainnet should be intentional"
    ],
    "environment": [
      "Primary stack: TypeScript (pnpm), Sui Move (edition 2024), Next.js + React",
      "Package manager is always pnpm, never npm or yarn",
      "Sui on-chain operations (publish, call, upgrade, transfer) are gated by a PreToolUse hook that checks the active network"
    ]
  },
  "defaultMode": "auto"
}
